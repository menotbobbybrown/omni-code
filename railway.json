{
  "$schema": "https://railway.app/chart.schema.json",
  "deploy": {
    "numReplicas": 2,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "variables": [
    {
      "name": "ENVIRONMENT",
      "value": "production"
    },
    {
      "name": "PYTHONUNBUFFERED",
      "value": "1"
    },
    {
      "name": "ENCRYPTION_KEY",
      "description": "32-byte Fernet encryption key for token encryption"
    },
    {
      "name": "JWT_SECRET",
      "description": "Secret for signing JWT tokens (should match NEXTAUTH_SECRET)"
    },
    {
      "name": "DATABASE_URL",
      "description": "PostgreSQL connection string"
    },
    {
      "name": "REDIS_URL",
      "description": "Redis connection string"
    }
  ],
  "healthCheck": {
    "path": "/health",
    "interval": 30,
    "timeout": 10,
    "startPeriod": 60
  },
  "resources": {
    "cpu": "500m",
    "memory": "512Mi"
  },
  "network": {
    "timeoutSeconds": 60
  }
}