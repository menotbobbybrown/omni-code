# OmniCode Environment Variables
# Copy to .env and fill in your values

# ===================
# SECURITY (Required in Production)
# ===================

# Fernet encryption key for token encryption
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-32-byte-url-safe-base64-encoded-key

# JWT secret for API token signing (should match NEXTAUTH_SECRET)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-at-least-16-characters

# ===================
# AUTHENTICATION
# ===================

# GitHub OAuth App credentials
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# NextAuth.js configuration
# Generate secret with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret

# ===================
# DATABASE
# ===================

# PostgreSQL connection (with pgvector extension)
# Format: postgresql://user:password@host:port/database
POSTGRES_USER=omnicode
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=omnicode
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://omnicode:your_secure_password@localhost:5432/omnicode

# ===================
# REDIS
# ===================

# Redis connection for caching and task queue
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ===================
# AI PROVIDERS
# ===================

# OpenAI API key for GPT models
OPENAI_API_KEY=your-openai-api-key

# GitHub token for API access (encrypted at rest)
GITHUB_TOKEN=

# ===================
# APPLICATION SETTINGS
# ===================

# Environment: development, staging, or production
ENVIRONMENT=development
DEBUG=true

# CORS origins (comma-separated in development)
CORS_ORIGINS=http://localhost:3000

# Rate limiting (requests per minute)
RATE_LIMIT_PER_MINUTE=60

# ===================
# RAILWAY DEPLOYMENT
# ===================

# Railway will auto-detect these from your service connections
# Override if needed:
# PORT=8000
# REDIS_URL=redis://redis.railway:6379